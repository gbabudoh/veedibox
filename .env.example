# Database
# connection_limit/pool_timeout matter once you're not on a pooled/managed Postgres (e.g. PgBouncer,
# Neon, Supabase) — without them, `next build`'s parallel static-generation workers can exhaust a
# small Postgres instance's max_connections.
DATABASE_URL="postgresql://veedibox:veedibox@localhost:5432/veedibox?schema=public&connection_limit=5&pool_timeout=10"

# Auth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="replace-with-a-long-random-string"

# MinIO (S3-compatible storage)
MINIO_ENDPOINT="localhost"
MINIO_PORT="9000"
MINIO_USE_SSL="false"
MINIO_ACCESS_KEY="veedibox"
MINIO_SECRET_KEY="veedibox-secret"
MINIO_BUCKET_ORIGINALS="veedibox-originals"
MINIO_BUCKET_PREVIEWS="veedibox-previews"

# imgproxy
# Leave IMGPROXY_KEY/IMGPROXY_SALT blank if your imgproxy server runs unsigned (no key/salt set
# on it either) — imgproxyUrl() falls back to the "insecure" signature segment automatically.
# Only fill these in if imgproxy itself is configured with matching IMGPROXY_KEY/IMGPROXY_SALT.
IMGPROXY_HOST="localhost:8080"
IMGPROXY_USE_SSL="false"
IMGPROXY_KEY=""
IMGPROXY_SALT=""

# Stripe
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
STRIPE_PUBLISHABLE_KEY="pk_test_..."
