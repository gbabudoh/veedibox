# Database
DATABASE_URL="postgresql://veedibox:veedibox@localhost:5432/veedibox?schema=public"

# Auth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="replace-with-a-long-random-string"

# MinIO (S3-compatible storage)
MINIO_ENDPOINT="localhost"
MINIO_PORT="9000"
MINIO_USE_SSL="false"
MINIO_ACCESS_KEY="veedibox"
MINIO_SECRET_KEY="veedibox-secret"
MINIO_BUCKET_ORIGINALS="veedibox-originals"
MINIO_BUCKET_PREVIEWS="veedibox-previews"

# imgproxy
IMGPROXY_HOST="localhost:8080"
IMGPROXY_USE_SSL="false"
IMGPROXY_KEY="replace-with-hex-key"
IMGPROXY_SALT="replace-with-hex-salt"

# Stripe
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
STRIPE_PUBLISHABLE_KEY="pk_test_..."
